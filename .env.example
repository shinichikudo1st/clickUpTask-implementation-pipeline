PORT=8080

# Required from Phase 1 onward (minimum 8 characters). Also used for Phase 9 manual routes
# (Bearer or X-API-Secret): POST /v1/tasks/{clickup_task_id}/generate, GET /v1/tasks/{clickup_task_id}/plan.
API_SECRET=
DATABASE_URL=

# Phase 2: PostgreSQL (Supabase → Settings → Database → URI). Must use sslmode=require or verify-*.

# Phase 2+ integrations
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# Default bucket name for milestone .md uploads is milestone-plans if unset.
# SUPABASE_STORAGE_BUCKET=milestone-plans
# Phase 6: object storage (local dir OR Supabase; orchestration wires this in Phase 8).
# STORAGE_BACKEND=auto
# STORAGE_LOCAL_DIR=
# Signed download URL lifetime for Supabase (seconds). Default 900 when unset or 0; min 60; max 604800.
# SIGNED_URL_TTL_SECONDS=900
# CLICKUP_API_TOKEN=
# Optional override (default https://api.clickup.com/api/v2).
# CLICKUP_API_BASE_URL=
# Required for POST /v1/webhooks/clickup (HMAC secret from Create Webhook response).
# CLICKUP_WEBHOOK_SECRET=
# CLICKUP_TEAM_ID=
# Optional: when set, only assignee-change events count for milestone runs — taskCreated is ignored
# so plans run when you are assigned (taskAssigneeUpdated / taskUpdated assignee_add), not on bare create.
# CLICKUP_ASSIGNEE_USER_ID=
# Phase 10 poller (optional). Off by default. Requires TEAM_ID + ASSIGNEE_USER_ID when enabled.
# CLICKUP_POLLER_ENABLED=false
# First-run window when watermark is at epoch (hours). Default 168.
# CLICKUP_POLLER_LOOKBACK_HOURS=168
# In-process ticker interval in seconds (min 30). 0 = no ticker (use: go run ./cmd/poll-milestones on a schedule).
# CLICKUP_POLL_INTERVAL_SECONDS=0
# Phase 5: milestone generation (OpenAI-compatible Chat Completions).
# LLM_PROVIDER=openai
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
# Optional; default https://api.openai.com/v1
# LLM_API_BASE_URL=
# Phase 7: Resend (https://resend.com). Leave unset or use noop/none to disable sending.
# EMAIL_PROVIDER=resend
# EMAIL_API_KEY=
# EMAIL_FROM=
# EMAIL_TO=
# Optional; default https://api.resend.com
# EMAIL_API_BASE_URL=
# Max markdown bytes to attach (default 450000); larger plans need DownloadURL in the send payload.
# EMAIL_MAX_ATTACHMENT_BYTES=
# APP_BASE_URL=
