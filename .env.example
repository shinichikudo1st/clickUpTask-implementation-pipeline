PORT=8080

# Required from Phase 1 onward (minimum 8 characters).
API_SECRET=
DATABASE_URL=

# Phase 2: PostgreSQL (Supabase → Settings → Database → URI). Must use sslmode=require or verify-*.

# Phase 2+ integrations
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# Default bucket name for milestone .md uploads is milestone-plans if unset.
# SUPABASE_STORAGE_BUCKET=milestone-plans
# Phase 6: object storage (local dir OR Supabase; orchestration wires this in Phase 8).
# STORAGE_BACKEND=auto
# STORAGE_LOCAL_DIR=
# Signed download URL lifetime for Supabase (seconds). Default 3600; min 60; max 604800.
# SIGNED_URL_TTL_SECONDS=3600
# CLICKUP_API_TOKEN=
# Optional override (default https://api.clickup.com/api/v2).
# CLICKUP_API_BASE_URL=
# Required for POST /v1/webhooks/clickup (HMAC secret from Create Webhook response).
# CLICKUP_WEBHOOK_SECRET=
# CLICKUP_TEAM_ID=
# Optional: only accept assignee_add webhooks when after.id matches this ClickUp user id.
# CLICKUP_ASSIGNEE_USER_ID=
# Phase 5: milestone generation (OpenAI-compatible Chat Completions).
# LLM_PROVIDER=openai
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
# Optional; default https://api.openai.com/v1
# LLM_API_BASE_URL=
# Phase 7: Resend (https://resend.com). Leave unset or use noop/none to disable sending.
# EMAIL_PROVIDER=resend
# EMAIL_API_KEY=
# EMAIL_FROM=
# EMAIL_TO=
# Optional; default https://api.resend.com
# EMAIL_API_BASE_URL=
# Max markdown bytes to attach (default 450000); larger plans need DownloadURL in the send payload.
# EMAIL_MAX_ATTACHMENT_BYTES=
# APP_BASE_URL=
