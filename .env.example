PORT=8080

# Required from Phase 1 onward (minimum 8 characters).
API_SECRET=
DATABASE_URL=

# Phase 2: PostgreSQL (Supabase → Settings → Database → URI). Must use sslmode=require or verify-*.

# Phase 2+ integrations
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=
# CLICKUP_API_TOKEN=
# Optional override (default https://api.clickup.com/api/v2).
# CLICKUP_API_BASE_URL=
# Required for POST /v1/webhooks/clickup (HMAC secret from Create Webhook response).
# CLICKUP_WEBHOOK_SECRET=
# CLICKUP_TEAM_ID=
# Optional: only accept assignee_add webhooks when after.id matches this ClickUp user id.
# CLICKUP_ASSIGNEE_USER_ID=
# LLM_PROVIDER=
# LLM_API_KEY=
# LLM_MODEL=
# EMAIL_PROVIDER=
# EMAIL_API_KEY=
# EMAIL_FROM=
# EMAIL_TO=
# APP_BASE_URL=
